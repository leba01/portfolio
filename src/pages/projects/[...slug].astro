---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={`${project.data.title} | Lucas E. Brennan-Almaraz`} description={project.data.description}>
  <article class="py-12 max-w-2xl">
    <a href="/" class="text-sm transition-colors hover:text-[--color-accent]" style="color: var(--color-ink-tertiary);">&larr; Back</a>

    <h1 class="mt-8 text-3xl tracking-tight" style="font-family: Georgia, 'Times New Roman', serif;">{project.data.title}</h1>
    <p class="mt-2" style="color: var(--color-ink-secondary);">{project.data.description}</p>

    <div class="mt-4 flex flex-wrap gap-2">
      {project.data.technologies.map((tech: string) => (
        <span class="text-xs px-2 py-1 rounded-sm" style="background: var(--color-surface-raised); color: var(--color-ink-secondary);">
          {tech}
        </span>
      ))}
    </div>

    {(project.data.githubUrl || project.data.liveUrl) && (
      <div class="mt-4 flex gap-5 text-sm" style="color: var(--color-ink-tertiary);">
        {project.data.githubUrl && (
          <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[--color-accent] transition-colors">
            GitHub ↗
          </a>
        )}
        {project.data.liveUrl && (
          <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[--color-accent] transition-colors">
            Live ↗
          </a>
        )}
      </div>
    )}

    <div class="mt-10 prose prose-sm max-w-none
      prose-headings:font-normal prose-headings:tracking-tight
      prose-p:leading-relaxed
      prose-strong:font-medium
      prose-a:text-[--color-accent] prose-a:no-underline hover:prose-a:underline
      prose-em:text-[--color-ink-secondary]
      prose-hr:border-[--color-rule-faint]"
      style="--tw-prose-body: var(--color-ink); --tw-prose-headings: var(--color-ink); --tw-prose-links: var(--color-accent);">
      <Content />
    </div>
  </article>
</Base>
