---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={`${project.data.title} | Lucas Brennan-Almaraz`} description={project.data.description}>
  <article class="py-12">
    <a href="/" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">&larr; Back</a>

    <h1 class="mt-6 text-3xl font-bold tracking-tight">{project.data.title}</h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">{project.data.description}</p>

    <div class="mt-4 flex flex-wrap gap-2">
      {project.data.technologies.map((tech: string) => (
        <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-800 rounded-md text-gray-700 dark:text-gray-300">
          {tech}
        </span>
      ))}
    </div>

    {(project.data.githubUrl || project.data.liveUrl) && (
      <div class="mt-4 flex gap-4 text-sm">
        {project.data.githubUrl && (
          <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline">
            View Source
          </a>
        )}
        {project.data.liveUrl && (
          <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline">
            Live Site
          </a>
        )}
      </div>
    )}

    <div class="mt-8 prose dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
</Base>
